# ── 執行模式 ──────────────────────────────────────────────
# true = 完全不需要任何 API Key,使用內建模擬資料展示系統
MOCK_DATA_MODE=true
# 停用排程器(只跑 API / 測試時用)
DISABLE_SCHEDULER=false

# ── 資料庫 / 快取 ─────────────────────────────────────────
# Docker Compose 內請用:postgresql+psycopg://xauusd:xauusd@db:5432/xauusd
# 本機快速展示可用 SQLite:sqlite:///./xauusd.db
DATABASE_URL=sqlite:///./xauusd.db
# 留空 = 不使用 Redis(改用行程內記憶體快取)
REDIS_URL=

# ── 主要行情 Provider ─────────────────────────────────────
# auto = mock 模式用 mock;否則 MT5 → Capital.com → OANDA → Twelve Data
# twelve_data = 無券商帳戶模式(免費層獨撐:5 分鐘輪詢 + K 棒邊界快取,~450 次/日)
PRIMARY_PROVIDER=auto

# ── MT5 / TMGM(主力;經由本機已登入的 MetaTrader 5 終端機)─
# 前置:Windows 安裝 MT5 終端機並登入 TMGM 帳戶,然後 pip install MetaTrader5
# 預設直接附掛已登入的終端機,以下全部可留空(免存帳密,建議)
MT5_SYMBOL=XAUUSD
MT5_TERMINAL_PATH=
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
# 伺服器時差(小時);留空 = 開盤時自動偵測(TMGM 慣例:冬令+2/夏令+3)
MT5_SERVER_UTC_OFFSET_HOURS=

# ── Capital.com(備選;Demo 帳戶免費 REST API)────────────
# 平台 Settings → API integrations → Generate new key(需設定 API Key 專用密碼)
CAPITAL_API_KEY=
CAPITAL_IDENTIFIER=
CAPITAL_API_PASSWORD=
CAPITAL_DEMO=true
CAPITAL_EPIC=GOLD

# ── OANDA Practice(備選;免費模擬帳戶)──────────────────
# 申請:https://www.oanda.com/demo-account/tpa/personal_token
OANDA_ENV=practice
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=

# ── Twelve Data(免費層備援行情:800 次/日、8 次/分)─────
# 申請:https://twelvedata.com/pricing
TWELVE_DATA_API_KEY=

# ── 經濟事件(Phase 6 使用;MVP 只載入 manual_events.json)─
FINNHUB_API_KEY=
FMP_API_KEY=
FRED_API_KEY=

# ── Telegram 通知(MVP 必要;留空則通知只寫入 log)────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 分級通知門檻(靜默 heartbeat):DEBUG<INFO<WARN<ERROR
# WARN(預設)= 一切正常時手機不響,只有資料延遲/異常才推播
NOTIFY_LEVEL=WARN
# ERROR 通知前綴(群組可填 @yourname;私聊留空)
TELEGRAM_MENTION=
# 最新 K 棒落後現在超過此分鐘數 → 推 WARN 資料延遲
DATA_LAG_WARN_MINUTES=60

# ── LLM(Phase 7 才會使用;MVP 不呼叫)────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_DAILY_BUDGET_USD=3.0

# ── 硬性安全開關(預設一律關閉)───────────────────────────
AUTO_TRADING_ENABLED=false
TRADINGVIEW_WEBHOOK_ENABLED=false

# ── 規則參數(全部可調;詳見 app/config.py 註解)──────────
# SOURCE_MISMATCH 門檻:max(百分比, ATR 倍數 × 15M ATR)
SOURCE_MISMATCH_PCT=0.0005
SOURCE_MISMATCH_ATR_MULT=0.3
# 追價偵測:進場距最近結構點超過此 15M ATR 倍數即標記
CHASE_ATR_MULT=1.5
# 距強支撐/壓力少於此 15M ATR 倍數禁止追空/追多
NO_CHASE_NEAR_LEVEL_ATR_MULT=0.75
# 高影響事件前鎖定分鐘數
EVENT_LOCKOUT_MINUTES=30
# 即時報價超過此秒數未更新(且非休市)標記 STALE
STALE_PRICE_SECONDS=60
# 市場結構 Swing 確認參數
SWING_LEFT_BARS=2
SWING_RIGHT_BARS=2
SWING_MIN_ATR_MULT=0.5
# Golden Dataset 驗收門檻(命中率低於此值測試失敗)
GOLDEN_DATASET_MIN_HIT_RATE=0.85
# 通知冷卻(秒)
NOTIFY_COOLDOWN_SECONDS=900
# Heartbeat 間隔(分鐘)
HEARTBEAT_MINUTES=30
